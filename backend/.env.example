# Server
PORT=3000
NODE_ENV=development

# LLM Provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Embedding Provider: minilm | openai
EMBEDDING_PROVIDER=minilm
EMBEDDING_DIMENSION=384

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Blockchain
RPC_URL=https://rpc.testnet.arc.network
CHAIN_ID=5042002
ORDERBOOK_ADDRESS=
VALIDATION_ORACLE_ADDRESS=

# IPFS (Pinata)
PINATA_API_KEY=
PINATA_SECRET_KEY=

# PostgreSQL
DATABASE_URL=

# Circle Nanopayments
PAYMENT_RECEIVER_ADDRESS=
USDC_ADDRESS=
